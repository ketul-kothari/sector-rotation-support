// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © Fundamental Dashboard - 3 Section Layout

//@version=6
indicator("Fundamental Dashboard", overlay=true)

// === User Inputs ===
quartersToShow = input.int(8, 'Quarters to Display', minval=4, maxval=12)
datasize = quartersToShow + 5

// === Display Settings ===
tableY = input.string('top', 'Vertical', options=['top', 'middle', 'bottom'])
tableX = input.string('right', 'Horizontal', options=['left', 'center', 'right'])
TextSize = input.string('tiny', 'Text Size', options=['tiny', 'small', 'normal'])

// === Theme ===
HeaderBGColor = color.new(#1a365d, 10)
RowBGColor = color.new(#1a1a2e, 20)
SeasonalBG = color.new(color.orange, 70)
NonSeasonalBG = color.new(color.teal, 70)

UpColor = color.lime
DownColor = color.red
FlatColor = color.gray
GoodColor = color.lime
OkColor = color.yellow
BadColor = color.red

// === Financial IDs ===
EPS_ID = 'EARNINGS_PER_SHARE'
SALES_ID = 'TOTAL_REVENUE'
ROE_ID = 'RETURN_ON_EQUITY'
DE_ID = 'DEBT_TO_EQUITY'

// === Stock Info Data ===
totalShares = request.financial(syminfo.tickerid, "TOTAL_SHARES_OUTSTANDING", "FY")
// Use daily close for all price comparisons (accurate on any chart timeframe)
dailyClose = request.security(syminfo.tickerid, "D", close)
marketCapCrores = (dailyClose * totalShares) / 10000000

week52High = request.security(syminfo.tickerid, "D", ta.highest(high, 252))
week52Low = request.security(syminfo.tickerid, "D", ta.lowest(low, 252))
pctAbove52Low = ((dailyClose - week52Low) / week52Low) * 100
pctBelow52High = ((week52High - dailyClose) / week52High) * 100

sma200 = request.security(syminfo.tickerid, "D", ta.sma(close, 200))
sma150 = request.security(syminfo.tickerid, "D", ta.sma(close, 150))
sma50  = request.security(syminfo.tickerid, "D", ta.sma(close, 50))
sma200_1M = request.security(syminfo.tickerid, "D", ta.sma(close[21], 200))
sma200_3M = request.security(syminfo.tickerid, "D", ta.sma(close[63], 200))
sma200Pct1M = na(sma200) or na(sma200_1M) or sma200_1M == 0 ? na : ((sma200 - sma200_1M) / sma200_1M) * 100
sma200Pct3M = na(sma200) or na(sma200_3M) or sma200_3M == 0 ? na : ((sma200 - sma200_3M) / sma200_3M) * 100
sma200Trend1M = na(sma200) or na(sma200_1M) ? "N/A" : sma200 > sma200_1M ? "Rising" : "Declining"
sma200Trend3M = na(sma200) or na(sma200_3M) ? "N/A" : sma200 > sma200_3M ? "Rising" : "Declining"

// Price distance from SMAs (daily)
pricePctVsSma200 = not na(sma200) and sma200 > 0 ? ((dailyClose - sma200) / sma200) * 100 : na
pricePctVsSma150 = not na(sma150) and sma150 > 0 ? ((dailyClose - sma150) / sma150) * 100 : na
pricePctVsSma50  = not na(sma50)  and sma50  > 0 ? ((dailyClose - sma50)  / sma50)  * 100 : na
sma150PctVsSma200 = not na(sma150) and not na(sma200) and sma200 > 0 ? ((sma150 - sma200) / sma200) * 100 : na
sma50PctVsSma150  = not na(sma50)  and not na(sma150) and sma150  > 0 ? ((sma50  - sma150)  / sma150)  * 100 : na
sma50PctVsSma200  = not na(sma50)  and not na(sma200) and sma200  > 0 ? ((sma50  - sma200)  / sma200)  * 100 : na

// === Minervini Trend Template Criteria ===
// C1: Price at least 30% above 52-week low
// C2: Price within 25% of 52-week high
// C3: Price above 200-day SMA
// C4: Price above 150-day SMA
// C5: 150-day SMA above 200-day SMA
// C6: 200-day SMA trending up (1-month)
// C7: Price above 50-day SMA
// C8: 50-day SMA above both 150-day and 200-day SMA
c1_above52Low      = pctAbove52Low >= 30
c2_below52High     = pctBelow52High <= 25
c3_priceVsSma200   = not na(sma200) and dailyClose > sma200
c4_priceVsSma150   = not na(sma150) and dailyClose > sma150
c5_sma150VsSma200  = not na(sma150) and not na(sma200) and sma150 > sma200
c6_sma200Rising    = sma200Trend1M == "Rising"
c7_priceVsSma50    = not na(sma50)  and dailyClose > sma50
c8_sma50VsHigherSmas = not na(sma50) and not na(sma150) and not na(sma200) and sma50 > sma150 and sma50 > sma200
c8a_sma50VsSma150    = not na(sma50) and not na(sma150) and sma50 > sma150
c8b_sma50VsSma200    = not na(sma50) and not na(sma200) and sma50 > sma200
templateScore = (c1_above52Low ? 1 : 0) + (c2_below52High ? 1 : 0) + (c3_priceVsSma200 ? 1 : 0) + (c4_priceVsSma150 ? 1 : 0) + (c5_sma150VsSma200 ? 1 : 0) + (c6_sma200Rising ? 1 : 0) + (c7_priceVsSma50 ? 1 : 0) + (c8_sma50VsHigherSmas ? 1 : 0)

// === Data Arrays ===
var array<int> dates = array.new_int(datasize)
var array<float> epsArr = array.new_float(datasize)
var array<float> salesArr = array.new_float(datasize)
var array<float> roeArr = array.new_float(datasize)
var array<float> deArr = array.new_float(datasize)

// === Fetch Financial Data ===
getData(id) =>
    request.financial(syminfo.tickerid, id, "FQ", barmerge.gaps_on, ignore_invalid_symbol=true)

eps = getData(EPS_ID)
sales = getData(SALES_ID)
roe = getData(ROE_ID)
de = getData(DE_ID)

// === Update Arrays when new data arrives ===
if not na(eps)
    array.unshift(dates, time)
    array.unshift(epsArr, eps)
    array.unshift(salesArr, na(sales) ? na : sales / 10000000)
    array.unshift(roeArr, roe)
    array.unshift(deArr, de)
    array.pop(dates)
    array.pop(epsArr)
    array.pop(salesArr)
    array.pop(roeArr)
    array.pop(deArr)

// === Helper Functions ===
getQoQChange(arr, idx) =>
    val = array.get(arr, idx)
    cmp = array.get(arr, idx + 1)
    na(val) or na(cmp) or cmp == 0 ? na : (val - cmp) / math.abs(cmp) * 100

getYoYChange(arr, idx) =>
    val = array.get(arr, idx)
    cmp = array.get(arr, idx + 4)
    na(val) or na(cmp) or cmp == 0 ? na : (val - cmp) / math.abs(cmp) * 100

formatPct(val) =>
    na(val) ? "-" : (val > 0 ? "+" : "") + str.tostring(math.round(val)) + "%"

formatVal(val) =>
    na(val) ? "-" : str.tostring(val, "#.##")

getGrowthColor(val) =>
    na(val) ? FlatColor : val > 10 ? UpColor : val > 0 ? color.green : val > -10 ? color.orange : DownColor

passCell(pass) => pass ? "✓" : "✗"
passColor(pass) => pass ? GoodColor : BadColor

priceSmaText(pct) =>
    na(pct) ? "N/A" : (pct >= 0 ? "+" : "") + str.tostring(pct, "#.#") + "%"

getROEColor(val) =>
    na(val) ? FlatColor : val >= 15 ? GoodColor : val >= 10 ? OkColor : BadColor

getDEColor(val) =>
    na(val) ? FlatColor : val <= 0.5 ? GoodColor : val <= 1 ? OkColor : BadColor

getCapCat(val) =>
    na(val) ? "" : val >= 105000 ? "Large" : val >= 34700 ? "Mid" : val >= 1000 ? "Small" : "Micro"

formatMCap(val) =>
    na(val) ? "N/A" : val >= 100000 ? str.tostring(val / 100000, "#.##") + " L Cr" : val >= 1000 ? str.tostring(val / 1000, "#.##") + " K Cr" : str.tostring(val, "#.##") + " Cr"

// Reverse index to show oldest first (ascending order)
reverseIdx(i) =>
    quartersToShow - 1 - i

// === Create Table ===
// Rows: InfoHeader(1) + InfoData(11) + QuarterHeader(1) + General(3) + YoYHeader(1) + YoYData(2) + QoQHeader(1) + QoQData(2) = 22
numCols = quartersToShow + 1
// Info section 3-zone column splits: label | value | pass/fail
infoLbl = math.floor(float(numCols - 1) / 3.0)          // label end col  (~2 for ncols=9)
infoVal = math.floor(2.0 * float(numCols - 1) / 3.0)    // value end col  (~5 for ncols=9)
// pass zone: infoVal+1 .. numCols-1
var table t = table.new(tableY + '_' + tableX, numCols, 22, bgcolor=RowBGColor, frame_color=color.gray, border_color=color.gray, border_width=1)

// === Render Table ===
if barstate.islast
    row = 0
    
    // === SECTION 1: INFO (Rows 0-9) ===
    
    // Row 0: Info Header
    table.cell(t, 0, row, "Info", bgcolor=HeaderBGColor, text_color=color.white, text_size=TextSize)
    table.merge_cells(t, 0, row, infoLbl, row)
    table.cell(t, infoLbl + 1, row, "Value", bgcolor=HeaderBGColor, text_color=color.white, text_size=TextSize)
    table.merge_cells(t, infoLbl + 1, row, infoVal, row)
    table.cell(t, infoVal + 1, row, "Template", bgcolor=HeaderBGColor, text_color=color.white, text_size=TextSize)
    table.merge_cells(t, infoVal + 1, row, numCols - 1, row)
    row += 1
    
    // Row 1: Market Cap
    table.cell(t, 0, row, "Market Cap", bgcolor=RowBGColor, text_color=color.white, text_size=TextSize)
    table.merge_cells(t, 0, row, infoLbl, row)
    mcapValue = formatMCap(marketCapCrores) + " (" + getCapCat(marketCapCrores) + ")"
    table.cell(t, infoLbl + 1, row, mcapValue, bgcolor=RowBGColor, text_color=color.white, text_size=TextSize)
    table.merge_cells(t, infoLbl + 1, row, infoVal, row)
    table.cell(t, infoVal + 1, row, "—", bgcolor=RowBGColor, text_color=FlatColor, text_size=TextSize)
    table.merge_cells(t, infoVal + 1, row, numCols - 1, row)
    row += 1

    // Row 2: % Above 52 Week Low  [C1: >= 30%]
    table.cell(t, 0, row, "% Above 52w Low", bgcolor=RowBGColor, text_color=color.white, text_size=TextSize)
    table.merge_cells(t, 0, row, infoLbl, row)
    table.cell(t, infoLbl + 1, row, "+" + str.tostring(pctAbove52Low, "#.#") + "%", bgcolor=RowBGColor, text_color=color.green, text_size=TextSize)
    table.merge_cells(t, infoLbl + 1, row, infoVal, row)
    table.cell(t, infoVal + 1, row, passCell(c1_above52Low) + " >=30%", bgcolor=RowBGColor, text_color=passColor(c1_above52Low), text_size=TextSize)
    table.merge_cells(t, infoVal + 1, row, numCols - 1, row)
    row += 1

    // Row 3: % Below 52 Week High  [C2: <= 25%]
    table.cell(t, 0, row, "% Below 52w High", bgcolor=RowBGColor, text_color=color.white, text_size=TextSize)
    table.merge_cells(t, 0, row, infoLbl, row)
    table.cell(t, infoLbl + 1, row, "-" + str.tostring(pctBelow52High, "#.#") + "%", bgcolor=RowBGColor, text_color=color.red, text_size=TextSize)
    table.merge_cells(t, infoLbl + 1, row, infoVal, row)
    table.cell(t, infoVal + 1, row, passCell(c2_below52High) + " <=25%", bgcolor=RowBGColor, text_color=passColor(c2_below52High), text_size=TextSize)
    table.merge_cells(t, infoVal + 1, row, numCols - 1, row)
    row += 1

    // Row 4: Price vs SMA150 & SMA200  [C3 + C4]
    priceVsSmaLbl = priceSmaText(pricePctVsSma150) + " / " + priceSmaText(pricePctVsSma200)
    priceVsSmaColor = c3_priceVsSma200 and c4_priceVsSma150 ? color.green : c3_priceVsSma200 or c4_priceVsSma150 ? color.yellow : color.red
    table.cell(t, 0, row, "Price vs SMA150/200", bgcolor=RowBGColor, text_color=color.white, text_size=TextSize)
    table.merge_cells(t, 0, row, infoLbl, row)
    table.cell(t, infoLbl + 1, row, priceVsSmaLbl, bgcolor=RowBGColor, text_color=priceVsSmaColor, text_size=TextSize)
    table.merge_cells(t, infoLbl + 1, row, infoVal, row)
    table.cell(t, infoVal + 1, row, passCell(c4_priceVsSma150) + "150 " + passCell(c3_priceVsSma200) + "200", bgcolor=RowBGColor, text_color=priceVsSmaColor, text_size=TextSize)
    table.merge_cells(t, infoVal + 1, row, numCols - 1, row)
    row += 1

    // Row 7: Price vs SMA50  [C7: price > SMA50]
    table.cell(t, 0, row, "Price vs SMA50", bgcolor=RowBGColor, text_color=color.white, text_size=TextSize)
    table.merge_cells(t, 0, row, infoLbl, row)
    table.cell(t, infoLbl + 1, row, priceSmaText(pricePctVsSma50), bgcolor=RowBGColor, text_color=c7_priceVsSma50 ? color.green : color.red, text_size=TextSize)
    table.merge_cells(t, infoLbl + 1, row, infoVal, row)
    table.cell(t, infoVal + 1, row, passCell(c7_priceVsSma50) + " P>50", bgcolor=RowBGColor, text_color=passColor(c7_priceVsSma50), text_size=TextSize)
    table.merge_cells(t, infoVal + 1, row, numCols - 1, row)
    row += 1

    // Row 8: SMA50 vs SMA150 & SMA200  [C8: SMA50 > SMA150 AND SMA50 > SMA200]
    sma50Lbl = na(sma50PctVsSma150) or na(sma50PctVsSma200) ? "N/A" : priceSmaText(sma50PctVsSma150) + " / " + priceSmaText(sma50PctVsSma200)
    sma50VsSmaColor = c8a_sma50VsSma150 and c8b_sma50VsSma200 ? color.green : c8a_sma50VsSma150 or c8b_sma50VsSma200 ? color.yellow : color.red
    table.cell(t, 0, row, "SMA50 vs SMA150/200", bgcolor=RowBGColor, text_color=color.white, text_size=TextSize)
    table.merge_cells(t, 0, row, infoLbl, row)
    table.cell(t, infoLbl + 1, row, sma50Lbl, bgcolor=RowBGColor, text_color=sma50VsSmaColor, text_size=TextSize)
    table.merge_cells(t, infoLbl + 1, row, infoVal, row)
    table.cell(t, infoVal + 1, row, passCell(c8a_sma50VsSma150) + "150 " + passCell(c8b_sma50VsSma200) + "200", bgcolor=RowBGColor, text_color=sma50VsSmaColor, text_size=TextSize)
    table.merge_cells(t, infoVal + 1, row, numCols - 1, row)
    row += 1

    // Row 9: SMA150 vs SMA200  [C5: SMA150 > SMA200]
    table.cell(t, 0, row, "SMA150 vs SMA200", bgcolor=RowBGColor, text_color=color.white, text_size=TextSize)
    table.merge_cells(t, 0, row, infoLbl, row)
    table.cell(t, infoLbl + 1, row, priceSmaText(sma150PctVsSma200), bgcolor=RowBGColor, text_color=c5_sma150VsSma200 ? color.green : color.red, text_size=TextSize)
    table.merge_cells(t, infoLbl + 1, row, infoVal, row)
    table.cell(t, infoVal + 1, row, passCell(c5_sma150VsSma200) + " 150>200", bgcolor=RowBGColor, text_color=passColor(c5_sma150VsSma200), text_size=TextSize)
    table.merge_cells(t, infoVal + 1, row, numCols - 1, row)
    row += 1

    // Row 8: SMA200 1-Month Trend  [C6: Rising]
    table.cell(t, 0, row, "SMA200 (1M Trend)", bgcolor=RowBGColor, text_color=color.white, text_size=TextSize)
    table.merge_cells(t, 0, row, infoLbl, row)
    sma1MColor = sma200Trend1M == "Rising" ? color.green : sma200Trend1M == "Declining" ? color.red : color.white
    sma1MText = sma200Trend1M + (na(sma200Pct1M) ? "" : " (" + (sma200Pct1M > 0 ? "+" : "") + str.tostring(sma200Pct1M, "#.#") + "%)")
    table.cell(t, infoLbl + 1, row, sma1MText, bgcolor=RowBGColor, text_color=sma1MColor, text_size=TextSize)
    table.merge_cells(t, infoLbl + 1, row, infoVal, row)
    table.cell(t, infoVal + 1, row, passCell(c6_sma200Rising) + " Rising", bgcolor=RowBGColor, text_color=passColor(c6_sma200Rising), text_size=TextSize)
    table.merge_cells(t, infoVal + 1, row, numCols - 1, row)
    row += 1

    // Row 9: SMA200 3-Month Trend  [informational]
    table.cell(t, 0, row, "SMA200 (3M Trend)", bgcolor=RowBGColor, text_color=color.white, text_size=TextSize)
    table.merge_cells(t, 0, row, infoLbl, row)
    sma3MColor = sma200Trend3M == "Rising" ? color.green : sma200Trend3M == "Declining" ? color.red : color.white
    sma3MText = sma200Trend3M + (na(sma200Pct3M) ? "" : " (" + (sma200Pct3M > 0 ? "+" : "") + str.tostring(sma200Pct3M, "#.#") + "%)")
    table.cell(t, infoLbl + 1, row, sma3MText, bgcolor=RowBGColor, text_color=sma3MColor, text_size=TextSize)
    table.merge_cells(t, infoLbl + 1, row, infoVal, row)
    table.cell(t, infoVal + 1, row, "(info)", bgcolor=RowBGColor, text_color=FlatColor, text_size=TextSize)
    table.merge_cells(t, infoVal + 1, row, numCols - 1, row)
    row += 1

    // Row 10: RS Annual  [informational — not computable here, check external tool]
    table.cell(t, 0, row, "RS Annual Rank", bgcolor=RowBGColor, text_color=color.white, text_size=TextSize)
    table.merge_cells(t, 0, row, infoLbl, row)
    table.cell(t, infoLbl + 1, row, "See sector tool", bgcolor=RowBGColor, text_color=FlatColor, text_size=TextSize)
    table.merge_cells(t, infoLbl + 1, row, infoVal, row)
    table.cell(t, infoVal + 1, row, "? (ext)", bgcolor=RowBGColor, text_color=OkColor, text_size=TextSize)
    table.merge_cells(t, infoVal + 1, row, numCols - 1, row)
    row += 1

    // Row 11: Template Score
    scoreColor = templateScore >= 8 ? GoodColor : templateScore >= 6 ? OkColor : BadColor
    table.cell(t, 0, row, "Template Score", bgcolor=RowBGColor, text_color=color.white, text_size=TextSize)
    table.merge_cells(t, 0, row, infoLbl, row)
    table.cell(t, infoLbl + 1, row, str.tostring(templateScore) + " / 8 criteria", bgcolor=RowBGColor, text_color=scoreColor, text_size=TextSize)
    table.merge_cells(t, infoLbl + 1, row, infoVal, row)
    table.cell(t, infoVal + 1, row, templateScore >= 8 ? "✓ PASS" : templateScore >= 6 ? "~ PARTIAL" : "✗ FAIL", bgcolor=RowBGColor, text_color=scoreColor, text_size=TextSize)
    table.merge_cells(t, infoVal + 1, row, numCols - 1, row)
    row += 1
    
    // === Row 12: Header with quarter dates (ascending order) ===
    table.cell(t, 0, row, "METRIC", bgcolor=HeaderBGColor, text_color=color.white, text_size=TextSize)
    for i = 0 to quartersToShow - 1
        idx = reverseIdx(i)
        qDate = array.get(dates, idx)
        qLabel = na(qDate) ? "Q" + str.tostring(i) : str.format("{0, date, MMM-yy}", qDate)
        table.cell(t, i + 1, row, qLabel, bgcolor=HeaderBGColor, text_color=color.white, text_size=TextSize)
    row += 1
    
    // === SECTION 2: GENERAL RESULTS ===
    
    // Row 11: EPS values
    table.cell(t, 0, row, "EPS", bgcolor=RowBGColor, text_color=color.aqua, text_size=TextSize)
    for i = 0 to quartersToShow - 1
        idx = reverseIdx(i)
        table.cell(t, i + 1, row, formatVal(array.get(epsArr, idx)), bgcolor=RowBGColor, text_color=color.white, text_size=TextSize)
    row += 1
    
    // Row 12: ROE
    table.cell(t, 0, row, "ROE%", bgcolor=RowBGColor, text_color=color.orange, text_size=TextSize)
    for i = 0 to quartersToShow - 1
        idx = reverseIdx(i)
        roeVal = array.get(roeArr, idx)
        table.cell(t, i + 1, row, formatVal(roeVal), bgcolor=RowBGColor, text_color=getROEColor(roeVal), text_size=TextSize)
    row += 1
    
    // Row 13: D/E Ratio
    table.cell(t, 0, row, "D/E", bgcolor=RowBGColor, text_color=color.fuchsia, text_size=TextSize)
    for i = 0 to quartersToShow - 1
        idx = reverseIdx(i)
        deVal = array.get(deArr, idx)
        table.cell(t, i + 1, row, formatVal(deVal), bgcolor=RowBGColor, text_color=getDEColor(deVal), text_size=TextSize)
    row += 1
    
    // === SECTION 3: SEASONAL (YoY) ===
    
    // Row 14: Seasonal Header
    table.cell(t, 0, row, "YoY", bgcolor=SeasonalBG, text_color=color.white, text_size=TextSize)
    for i = 1 to quartersToShow
        table.cell(t, i, row, "", bgcolor=SeasonalBG, text_color=color.white, text_size=TextSize)
    row += 1
    
    // Row 15: EPS YoY
    table.cell(t, 0, row, "EPS", bgcolor=RowBGColor, text_color=color.yellow, text_size=TextSize)
    for i = 0 to quartersToShow - 1
        idx = reverseIdx(i)
        epsY = getYoYChange(epsArr, idx)
        table.cell(t, i + 1, row, formatPct(epsY), bgcolor=RowBGColor, text_color=getGrowthColor(epsY), text_size=TextSize)
    row += 1
    
    // Row 16: Revenue YoY
    table.cell(t, 0, row, "Rev", bgcolor=RowBGColor, text_color=color.yellow, text_size=TextSize)
    for i = 0 to quartersToShow - 1
        idx = reverseIdx(i)
        revY = getYoYChange(salesArr, idx)
        table.cell(t, i + 1, row, formatPct(revY), bgcolor=RowBGColor, text_color=getGrowthColor(revY), text_size=TextSize)
    row += 1
    
    // === SECTION 4: NON-SEASONAL (QoQ) ===
    
    // Row 17: Non-Seasonal Header
    table.cell(t, 0, row, "QoQ", bgcolor=NonSeasonalBG, text_color=color.white, text_size=TextSize)
    for i = 1 to quartersToShow
        table.cell(t, i, row, "", bgcolor=NonSeasonalBG, text_color=color.white, text_size=TextSize)
    row += 1
    
    // Row 18: EPS QoQ
    table.cell(t, 0, row, "EPS", bgcolor=RowBGColor, text_color=color.aqua, text_size=TextSize)
    for i = 0 to quartersToShow - 1
        idx = reverseIdx(i)
        epsQ = getQoQChange(epsArr, idx)
        table.cell(t, i + 1, row, formatPct(epsQ), bgcolor=RowBGColor, text_color=getGrowthColor(epsQ), text_size=TextSize)
    row += 1
    
    // Row 19: Revenue QoQ
    table.cell(t, 0, row, "Rev", bgcolor=RowBGColor, text_color=color.aqua, text_size=TextSize)
    for i = 0 to quartersToShow - 1
        idx = reverseIdx(i)
        revQ = getQoQChange(salesArr, idx)
        table.cell(t, i + 1, row, formatPct(revQ), bgcolor=RowBGColor, text_color=getGrowthColor(revQ), text_size=TextSize)

// Dummy plot
plot(na, display=display.none)
